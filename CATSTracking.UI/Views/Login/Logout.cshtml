@{
    ViewData["Title"] = "Confirm Logout";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            padding: 20px;
        }

        .logout-container {
            width: 100%;
            max-width: 450px;
            animation: fadeInUp 0.5s ease;
        }

        @@keyframes fadeInUp {
            from

        {
            opacity: 0;
            transform: translateY(30px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }

        }

        .modal-content {
            background: white;
            border-radius: 32px;
            padding: 0;
            position: relative;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
            overflow: hidden;
            border: 3px solid #ff6600;
        }

        .modal-header {
            padding: 40px 40px 20px;
            text-align: center;
            position: relative;
        }

        .close-btn {
            position: absolute;
            top: 20px;
            right: 20px;
            background: #f5f5f5;
            border: none;
            font-size: 1.3rem;
            color: #666;
            cursor: pointer;
            width: 35px;
            height: 35px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s ease;
            line-height: 1;
            text-decoration: none;
        }

            .close-btn:hover {
                background: #ff6600;
                color: white;
                transform: rotate(90deg);
            }

        .modal-title {
            color: #1a1a1a;
            font-size: 1.8rem;
            margin-bottom: 15px;
            font-weight: 700;
            line-height: 1.3;
        }

        .modal-subtitle {
            color: #999;
            font-size: 1rem;
            line-height: 1.6;
            margin-bottom: 25px;
            padding: 0 10px;
        }

        .modal-illustration {
            padding: 0 40px 35px;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .illustration-box {
            width: 220px;
            height: 180px;
            background: linear-gradient(135deg, #ff6600 0%, #ff9933 100%);
            border-radius: 28px;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow: hidden;
            box-shadow: 0 8px 25px rgba(255, 102, 0, 0.3);
        }

        .illustration-icon {
            font-size: 6rem;
            animation: wave 2s ease-in-out infinite;
        }

        @@keyframes wave {
            0%, 100%

        {
            transform: rotate(0deg);
        }

        25% {
            transform: rotate(20deg);
        }

        75% {
            transform: rotate(-20deg);
        }

        }

        .modal-buttons {
            display: flex;
            gap: 0;
            padding: 0;
            border-top: 1px solid #eee;
        }

        .modal-btn {
            flex: 1;
            padding: 20px;
            border: none;
            font-size: 1.05rem;
            cursor: pointer;
            transition: all 0.3s ease;
            font-weight: 600;
            background: white;
            text-decoration: none;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .btn-cancel {
            color: #666;
            border-right: 1px solid #eee;
        }

            .btn-cancel:hover {
                background: #f8f8f8;
                color: #1a1a1a;
            }

        .btn-confirm {
            color: #ff6600;
        }

            .btn-confirm:hover {
                background: #fff5f0;
                color: #ff8533;
            }

        @@media (max-width: 480px) {
            .modal-content

        {
            border-radius: 24px;
        }

        .modal-title {
            font-size: 1.5rem;
        }

        .modal-subtitle {
            font-size: 0.9rem;
        }

        .illustration-box {
            width: 180px;
            height: 150px;
        }

        .illustration-icon {
            font-size: 4.5rem;
        }

        }
    </style>
</head>
<body>
    <div class="logout-container">
        <div class="modal-content">
            <div class="modal-header">
                <a href="javascript:history.back()" class="close-btn">&times;</a>
                <h2 class="modal-title">Want to log out?</h2>
                <p class="modal-subtitle">You can always log back in whenever you want, please feel free to come back again</p>
            </div>


            <div class="modal-buttons">
                <a href="javascript:history.back()" class="modal-btn btn-cancel">No, Not Yet</a>
                <a href="@Url.Action("Logout", "Login")" class="modal-btn btn-confirm">Yes</a>
            </div>
        </div>
    </div>
</body>
</html>