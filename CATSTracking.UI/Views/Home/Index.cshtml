@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TrackIT - Track Your Assets with Precision</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="manifest" href="~/manifest.json" />
    <link rel="stylesheet" href="~/css/home.css" />
</head>
<body>
    <section class="hero-section">
        <div class="hero-background">
            <img src="/images/home.jpg" alt="TrackIT Background">
        </div>
        <div class="hero-overlay"></div>


        <nav class="navbar">
            <div class="logo">
                <div class="logo-icon">
                    <i class="fas fa-location-arrow"></i>
                </div>
                <div class="logo-text">Track<span>IT</span></div>
            </div>
            <a href="/Login/Index" class="nav-link">Login</a>
        </nav>

        <div class="hero-content">
            <h1 class="hero-title">Track Your Assets with <span>Precision</span></h1>
            <p class="hero-subtitle">
                Real-time container tracking and asset management solutions. Monitor your shipments, optimize logistics, and gain complete visibility across your supply chain with powerful tracking technology.
            </p>
        </div>

        <div class="features-bar">
            <div class="features-bar-content">
                <div class="feature-item">
                    <div class="feature-icon">
                        <i class="fas fa-globe"></i>
                    </div>
                    <div class="feature-title">Real-Time Tracking</div>
                </div>
                <div class="feature-item">
                    <div class="feature-icon">
                        <i class="fas fa-shield-alt"></i>
                    </div>
                    <div class="feature-title">Secure & Reliable</div>
                </div>
                <div class="feature-item">
                    <div class="feature-icon">
                        <i class="fas fa-chart-line"></i>
                    </div>
                    <div class="feature-title">Analytics Dashboard</div>
                </div>
                <div class="feature-item">
                    <div class="feature-icon">
                        <i class="fas fa-headset"></i>
                    </div>
                    <div class="feature-title">24/7 Support</div>
                </div>
            </div>
        </div>
    </section>


    <section class="services-section">
        <div class="section-header">
            <h2 class="section-title">What We <span>Offer</span></h2>
            <p class="section-subtitle">Comprehensive tracking and asset management solutions tailored to your business needs</p>
        </div>

        <div class="services-grid">
            
            <div class="service-card">
                <div class="service-icon-wrapper">
                    <i class="fas fa-shield-alt"></i>
                </div>
                <h3 class="service-title">Secure Container Tracking</h3>
                <p class="service-description">
                    Track your containers and goods safely and in real time. Our system ensures every
                    movement is monitored and protected from start to finish.
                </p>
            </div>


            <div class="service-card">
                <div class="service-icon-wrapper">
                    <i class="fas fa-bell"></i>
                </div>
                <h3 class="service-title">Instant Alerts & Notifications</h3>
                <p class="service-description">
                    Receive immediate updates on container activity - including movements, arrivals,
                    and key status changes so you’re always informed.
                </p>
            </div>

            
            <div class="service-card">
                <div class="service-icon-wrapper">
                    <i class="fas fa-users-cog"></i>
                </div>
                <h3 class="service-title">Reliable Client Support</h3>
                <p class="service-description">
                    Enjoy dedicated customer assistance and dependable system uptime. Our team ensures
                    your tracking operations run smoothly every day.
                </p>
            </div>
        </div>
    </section>


    <section class="contact-section">
        <div class="contact-container">
            <div class="contact-info">
                <h2 class="contact-title">Get In <span>Touch</span></h2>
                <p class="contact-description">
                    Have questions or ready to transform your asset tracking?
                </p>

                <div class="contact-details">
                    <div class="contact-item">
                        <div class="contact-item-icon">
                            <i class="fas fa-map-marker-alt"></i>
                        </div>
                        <div class="contact-item-content">
                            <h3>Visit Us</h3>
                            <p>49 Warberson Avaenue, Bluff 4052<br>KwaZulu-Natal, South Africa</p>
                        </div>
                    </div>

                    <div class="contact-item">
                        <div class="contact-item-icon">
                            <i class="fas fa-phone"></i>
                        </div>
                        <div class="contact-item-content">
                            <h3>Call Us</h3>
                            <p>+27 (31) 466 2608<br>+27 (31) 466 4077</p>
                        </div>
                    </div>

                    <div class="contact-item">
                        <div class="contact-item-icon">
                            <i class="fas fa-envelope"></i>
                        </div>
                        <div class="contact-item-content">
                            <h3>Email Us</h3>
                            <p>info@cats.africa</p>
                        </div>
                    </div>
                </div>

                <div class="social-links">
                    <a href="https://www.facebook.com/people/CATS-Container-Assets-Tracking-Services-Logistics/100048570296993/" target="_blank" class="social-link"><i class="fab fa-facebook-f"></i></a>
                </div>
            </div>
        </div>
    </section>

    <footer class="footer">
        <p>&copy; 2025 TrackIT. All rights reserved. <a href="/Home/Privacy">Privacy Policy</a></p>

    </footer>
</body>
</html>