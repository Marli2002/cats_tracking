@{
    ViewBag.Title = "User Settings";
}

<link rel="stylesheet" href="~/css/settings.css" />
<link rel="stylesheet" href="~/css/usersettings2.css" />

<body>
    <div class="settings-header">
        <h2>User Settings</h2>
        <p>Manage your personal information and account security</p>
    </div>

    <div class="settings-container">
        <div class="settings-card">
            <div class="settings-icon"><i class="fas fa-user-edit"></i></div>
            <div class="settings-title">Edit Profile</div>
            <div class="settings-description">
                Update your name or email address.
            </div>
            <a href="/User/EditProfile" class="back-btn">Open</a>
        </div>

        <div class="settings-card">
            <div class="settings-icon"><i class="fas fa-lock"></i></div>
            <div class="settings-title">Change Password</div>
            <div class="settings-description">
                Update your password for better account security.
            </div>
            <a href="/User/ChangePassword" class="back-btn">Open</a>
        </div>
    </div>

    <div style="text-align:center;">
        <a href="/User/Dashboard" class="back-btn">Back to Dashboard</a>
    </div>
</body>
