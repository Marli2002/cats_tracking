@{
    ViewBag.Title = "Settings";
    var listenerAddress = ViewBag.ListenerAddress as string ?? "";
    var twilioKey = ViewBag.TwilioKey as string ?? "";
    var twilioSecret = ViewBag.TwilioSecret as string ?? "";
    var twilioPhone = ViewBag.TwilioPhone as string ?? "";
}
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Admin Settings</title>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<link rel="stylesheet" href="~/css/settings.css" />
<body>
    <div class="settings-header">
        <h2>Admin Settings</h2>
        <p>Manage system configuration</p>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">
            <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-error">
            <i class="fas fa-exclamation-circle"></i> @TempData["ErrorMessage"]
        </div>
    }

    <div class="settings-container">
        <div class="settings-form-card">
            <form id="settingsForm" method="post" action="/Admin/SaveSettings">
                @Html.AntiForgeryToken()

                <div class="form-section">
                    <h3><i class="fas fa-server"></i> Listener Server Configuration</h3>
                    <div class="form-group">
                        <label for="listenerAddress">Listener Server Address</label>
                        <input type="text"
                               id="listenerAddress"
                               name="ListenerAddress"
                               value="@listenerAddress"
                               placeholder="https://listener.example.com"
                               required />
                    </div>
                </div>

                <div class="form-section">
                    <h3><i class="fas fa-phone"></i> Twilio Configuration</h3>
                    <div class="form-group">
                        <label for="twilioKey">Twilio Account ID</label>
                        <input type="text"
                               id="twilioKey"
                               name="TwilioKey"
                               value="@twilioKey"
                               placeholder=""
                               required />
                    </div>

                    <div class="form-group">
                        <label for="twilioSecret">Twilio Auth Token</label>
                        <input type="password"
                               id="twilioSecret"
                               name="TwilioSecret"
                               value="@twilioSecret"
                               placeholder="Enter auth token"
                               required />
                        <span class="toggle-password" onclick="togglePassword()">
                            <i class="fas fa-eye" id="toggleIcon"></i>
                        </span>
                    </div>

                    <div class="form-group">
                        <label for="twilioPhone">Twilio Phone Number</label>
                        <input type="tel"
                               id="twilioPhone"
                               name="TwilioPhone"
                               value="@twilioPhone"
                               placeholder="+1234567890"
                               required />
                    </div>
                </div>

                <div class="form-actions">
                    <button type="submit" class="save-btn">
                        Save Settings
                    </button>
                    <a href="/Admin/Dashboard" class="back-btn">
                       Back to Dashboard
                    </a>
                </div>
            </form>
        </div>
    </div>

    <script>
    function togglePassword() {
    const passwordField = document.getElementById('twilioSecret');
    const toggleIcon = document.getElementById('toggleIcon');
    if (passwordField.type === 'password') {
    passwordField.type = 'text';
    toggleIcon.classList.remove('fa-eye-slash');
    toggleIcon.classList.add('fa-eye');
    } else {
    passwordField.type = 'password';
    toggleIcon.classList.remove('fa-eye');
    toggleIcon.classList.add('fa-eye-slash');
    }
    }
    </script>
</body>