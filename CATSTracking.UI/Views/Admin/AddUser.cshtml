@model CATSTracking.Library.Models.UserProfile
@{
    ViewBag.Title = "Add User";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/addUser.css" />
}

<div class="page-content">
    <div class="page-wrapper">
        <div class="form-container">
            <div class="form-header">
                <h1 class="form-title">Add New User</h1>
                <p class="form-subtitle">Fill in the information below to create a new user account</p>
            </div>

            <form id="userForm">
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">First Name <span class="required">*</span></label>
                        <input type="text" class="form-input" id="FirstName" name="FirstName" placeholder="Enter first name"
                            required />
                    </div>

                    <div class="form-group">
                        <label class="form-label">Last Name <span class="required">*</span></label>
                        <input type="text" class="form-input" id="LastName" name="LastName" placeholder="Enter last name" required />
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Login ID / Email <span class="required">*</span></label>
                    <input type="email" class="form-input" id="LoginId" name="LoginId" placeholder="Enter email address" required />
                </div>

                <div class="form-group">
                    <label class="form-label">API User <span class="required">*</span></label>
                    <select class="form-select" id="APIUser" name="APIUser" required>
                        <option value="false">No</option>
                        <option value="true">Yes</option>
                    </select>
                </div>

                <div class="alert-info" style="padding: 12px; background: #e3f2fd; border-radius: 8px; margin-bottom: 20px;">
                    <p style="margin: 0; color: #1976d2;">
                        <strong>Note:</strong> New users will be created with the default password: <code>Default@123</code>
                    </p>
                </div>

                <div class="btn-group">
                    <a href="@Url.Action("UsersList", "Admin")" class="btn btn-secondary">Back to List</a>
                    <button type="submit" class="btn btn-primary">Add User</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('userForm').addEventListener('submit', async function (e) {
            e.preventDefault(); // Prevent default form submission

            const formData = {
                FirstName: this.FirstName.value.trim(),
                LastName: this.LastName.value.trim(),
                LoginId: this.LoginId.value.trim(),
                APIUser: this.APIUser.value === 'true' // Convert string to boolean
            };

            if (!formData.FirstName || !formData.LastName || !formData.LoginId) {
                alert("Please fill in all required fields."); // Only show alert for missing fields
                return;
            }

            try {
                const response = await fetch('/Admin/AddUser', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(formData)
                });

                const result = await response.json();

                if (result.success) {
                    // Redirect immediately to UsersList; toast will be shown there
                    window.location.href = '/Admin/UsersList';
                } else {
                    alert('Error adding user: ' + result.message); // Show error only
                }
            } catch (error) {
                console.error('Error:', error);
                alert('Error adding user: ' + error.message); // Show error only
            }
        });
    </script>
}


