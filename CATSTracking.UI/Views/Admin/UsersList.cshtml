@model IEnumerable<CATSTracking.Library.Models.UserProfile>
@{
    ViewBag.Title = "Users List";
    Layout = "~/Views/Shared/_Layout.cshtml";

}

@section Styles {
    <link rel="stylesheet" href="~/css/userList.css" />
}

<div class="page-content">
    <div class="page-header">
        <h1 class="page-title">Users List</h1>
        <p class="page-subtitle">View and manage all users in the system</p>
    </div>

    <div class="content-card">
        <div class="card-toolbar">
            <div class="search-wrapper">
                <svg class="search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="11" cy="11" r="8"></circle>
                    <path d="m21 21-4.35-4.35"></path>
                </svg>
                <input type="text" class="search-input" placeholder="Search by name or login..." id="searchInput" />
            </div>
        </div>

        <div class="table-responsive">
            <table class="users-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Login ID</th>
                        <th>API User</th>
                        <th style="text-align:center;">Actions</th>
                    </tr>
                </thead>
                <tbody id="usersTableBody">
                    @foreach (var user in Model)
                    {
                        <tr data-user-id="@user.Id">
                            <td class="user-name">@user.FirstName @user.LastName</td>
                            <td>@user.LoginId</td>
                            <td><span class="role-tag">@(user.APIUser ? "Yes" : "No")</span></td>
                            <td>
                                <div class="action-dropdown">
                                    <button class="dropdown-toggle" onclick="toggleDropdown(event, this)">
                                        Actions
                                    </button>
                                    <div class="dropdown-menu">
                                        <a href="@Url.Action("UserTracker", "Admin", new { userId = user.Id })" class="dropdown-item">
                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                                                <circle cx="12" cy="12" r="3"></circle>
                                            </svg>

                                            View Trackers
                                        </a>

                                        <a href="@Url.Action("EditUser", "Admin", new { id = user.Id })" class="dropdown-item">
                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                                                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                                            </svg>
                                            Edit
                                        </a>
                                        <button class="dropdown-item" onclick="handleResetLink('@user.LoginId')">
                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <polyline points="23 4 23 10 17 10"></polyline>
                                                <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"></path>
                                            </svg>
                                            Reset Link
                                        </button>
                                        <button class="dropdown-item delete" onclick="handleDelete('@user.Id', '@user.FirstName @user.LastName', this)">
                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <polyline points="3 6 5 6 21 6"></polyline>
                                                <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                                            </svg>
                                            Delete
                                        </button>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="user-cards">
            @foreach (var user in Model)
            {
                <div class="user-card" data-user-id="@user.Id" onclick="openUserModal('@user.Id', '@user.FirstName @user.LastName', '@user.LoginId', '@(user.APIUser ? "Yes" : "No")')">
                    <div class="user-card-name">@user.FirstName @user.LastName</div>
                    <div class="user-card-email">@user.LoginId</div>
                </div>
            }
        </div>
    </div>
</div>


<div class="floating-btn">
    <a href="@Url.Action("AddUser", "Admin")" class="add-user-btn">Add New User</a>
</div>

<div class="modal-overlay" id="userModal">
    <div class="modal-content">
        <div class="modal-header">
            <h2 class="modal-title" id="modalUserName"></h2>
            <button class="modal-close" onclick="closeUserModal()">×</button>
        </div>
        <div class="modal-body">
            <div class="modal-info-group">
                <div class="modal-info-label">Login ID</div>
                <div class="modal-info-value" id="modalLoginId"></div>
            </div>
            <div class="modal-info-group">
                <div class="modal-info-label">Company</div>
                <div class="modal-info-value" id="modalCompany"></div>
            </div>
            <div class="modal-info-group">
                <div class="modal-info-label">API User</div>
                <div class="modal-info-value">
                    <span class="role-tag" id="modalApiUser"></span>
                </div>
            </div>
        </div>
        <div class="modal-actions">
            <a href="#" class="btn-action btn-view" id="modalViewTrackers">View Trackers</a>
            <a href="Admin/EditUser" class="btn-action btn-edit" id="modalEditUser">Edit</a>
            <button class="btn-action btn-reset" id="modalResetLink">Reset Link</button>
            <button class="btn-action btn-delete" id="modalDeleteUser">Delete</button>
        </div>
    </div>
</div>

<script>
    window.addEventListener('DOMContentLoaded', function () {
        const message = '@TempData["Message"]';
        const error = '@TempData["Error"]';
        if (message && message.trim() !== "") showSuccessMessage(message);
        if (error && error.trim() !== "") showErrorMessage(error);
    });

    // Variables to store current selected user information
    // MDN Web Docs (2025) helped understand variable usage and scope
    let currentUserId = '';
    let currentUserName = '';
    let currentLoginId = '';

    // Search functionality for users table and cards
    // W3Schools (2025) helped understand 'input' event and DOM filtering
    document.getElementById('searchInput').addEventListener('input', function(e) {
        const searchTerm = e.target.value.toLowerCase();
        const rows = document.querySelectorAll('#usersTableBody tr');
        const cards = document.querySelectorAll('.user-card');

        // Filter table rows based on search term
        rows.forEach(row => {
            const text = row.textContent.toLowerCase();
            row.style.display = text.includes(searchTerm) ? '' : 'none';
        });

        // Filter user cards based on search term
        cards.forEach(card => {
            const text = card.textContent.toLowerCase();
            card.style.display = text.includes(searchTerm) ? '' : 'none';
        });
    });

    // Dropdown toggle functionality
    // MDN Web Docs (2025) helped understand event handling and DOM manipulation
    function toggleDropdown(event, button) {
        event.stopPropagation();
        const dropdown = button.nextElementSibling;
        const isOpen = dropdown.classList.contains('show');

        // Close all other dropdowns
        document.querySelectorAll('.dropdown-menu.show').forEach(menu => {
            menu.classList.remove('show');
        });

        // Toggle current dropdown
        if (!isOpen) {
            dropdown.classList.add('show');
        }
    }

    // Close dropdowns when clicking outside
    // MDN Web Docs (2025) helped understand document click events
    document.addEventListener('click', function(e) {
        if (!e.target.matches('.dropdown-toggle')) {
            document.querySelectorAll('.dropdown-menu.show').forEach(menu => {
                menu.classList.remove('show');
            });
        }
    });

    // Function to open the user modal with user details
    // MDN Web Docs (2025) helped understand classList manipulation and DOM textContent
    function openUserModal(userId, userName, loginId, company, apiUser) {
        currentUserId = userId;
        currentUserName = userName;
        currentLoginId = loginId;

        document.getElementById('modalUserName').textContent = userName;
        document.getElementById('modalLoginId').textContent = loginId;
        document.getElementById('modalCompany').textContent = company;
        document.getElementById('modalApiUser').textContent = apiUser;

        // Update modal action links using Razor Url.Action syntax
        document.getElementById('modalViewTrackers').href = '@Url.Action("UserTracker", "Admin")?id=' + userId;
        document.getElementById('modalEditUser').href = '@Url.Action("EditUser", "Admin")?id=' + userId;

        document.getElementById('modalResetLink').onclick = function() {
            handleResetLink(loginId);
        };

        document.getElementById('modalDeleteUser').onclick = function() {
            handleDeleteModal(userId, userName);
        };

        document.getElementById('userModal').classList.add('active');
        document.body.style.overflow = 'hidden'; // Prevent background scrolling
    }

    // Close the user modal
    function closeUserModal() {
        document.getElementById('userModal').classList.remove('active');
        document.body.style.overflow = '';
    }

    // Close modal if clicking outside content
    document.getElementById('userModal').addEventListener('click', function(e) {
        if (e.target === this) {
            closeUserModal();
        }
    });

    // Function to generate password reset link
    // W3Schools (2025) helped understand confirm() and alert() usage
    function handleResetLink(email) {
        // Close dropdown before showing alert
        document.querySelectorAll('.dropdown-menu.show').forEach(menu => {
            menu.classList.remove('show');
        });

        showResetConfirmation(email, () => {
            showSuccessMessage('Password reset link has been generated successfully!');
            closeUserModal();
        });
    }

    // Function to delete a user from table directly
    // W3Schools (2025) helped understand fetch API for POST requests
    function handleDelete(userId, userName, button) {
        // Close dropdown before showing confirm
        document.querySelectorAll('.dropdown-menu.show').forEach(menu => {
            menu.classList.remove('show');
        });

        showDeleteConfirmation(userName, () => {
            // Send POST request to AdminController.DeleteUser
            fetch('@Url.Action("DeleteUser", "Admin")?id=' + userId, { method: 'POST' })
            .then(response => {
                if (response.ok) {
                    // Remove row from table with animation
                    const row = button.closest('tr');
                    if (row) {
                        row.style.transition = 'opacity 0.3s';
                        row.style.opacity = '0';
                        setTimeout(() => row.remove(), 300);
                    }

                    // Remove corresponding card from mobile view
                    // MDN Web Docs (2025) helped understand querySelector usage
                    removeUserCard(userId);

                    showSuccessMessage('User deleted successfully!');
                } else {
                    showErrorMessage('Error deleting user. Please try again.');
                }
            })
            .catch(error => {
                console.error('Error:', error);
                showErrorMessage('Error deleting user. Please try again.');
            });
        });
    }

    // Function to delete a user from modal view
    function handleDeleteModal(userId, userName) {
        showDeleteConfirmation(userName, () => {
            // Send POST request to AdminController.DeleteUser, (MDN Web Docs (2025) helped understand fetch API))
            fetch('@Url.Action("DeleteUser", "Admin")?id=' + userId, { method: 'POST' })
            .then(response => {
                if (response.ok) {
                    // Remove card from mobile view with animation
                    removeUserCard(userId);

                    // Remove row from table
                    const row = document.querySelector(`#usersTableBody tr[data-user-id="${userId}"]`);
                    if (row) {
                        row.style.transition = 'opacity 0.3s';
                        row.style.opacity = '0';
                        setTimeout(() => row.remove(), 300);
                    }

                    closeUserModal();
                    showSuccessMessage('User deleted successfully!');
                } else {
                    showErrorMessage('Error deleting user. Please try again.');
                }
            })
            .catch(error => {
                console.error('Error:', error);
                showErrorMessage('Error deleting user. Please try again.');
            });
        });
    }

    // Helper function to remove user card by ID (works across viewport changes)
    // MDN Web Docs (2025) helped understand querySelector usage
    function removeUserCard(userId) {
        const card = document.querySelector(`.user-card[data-user-id="${userId}"]`);
        if (card) {
            card.style.transition = 'opacity 0.3s';
            card.style.opacity = '0';
            setTimeout(() => card.remove(), 300);
        }
    }

    // Confirmation dialog functions
    // W3Schools (2025) helped understand DOM manipulation and event handling
    function showDeleteConfirmation(userName, onConfirm) {
        const overlay = document.createElement('div');
        overlay.className = 'custom-confirm-overlay';
        overlay.innerHTML = `
            <div class="custom-confirm-dialog">
                <div class="confirm-icon delete-icon">
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="3 6 5 6 21 6"></polyline>
                        <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                    </svg>
                </div>
                <h3 class="confirm-title">Delete User</h3>
                <p class="confirm-message">Are you sure you want to delete <strong>${userName}</strong>?</p>
                <div class="confirm-actions">
                    <button class="confirm-btn cancel-btn" onclick="this.closest('.custom-confirm-overlay').remove()">Cancel</button>
                    <button class="confirm-btn delete-btn" id="confirmDeleteBtn">Delete</button>
                </div>
            </div>
        `;
        document.body.appendChild(overlay);
        setTimeout(() => overlay.classList.add('active'), 10);

        document.getElementById('confirmDeleteBtn').onclick = () => {
            overlay.remove();
            onConfirm();
        };
    }

    // Confirmation dialog functions
    // W3Schools (2025) helped understand DOM manipulation and event handling
    function showResetConfirmation(email, onConfirm) {
        const overlay = document.createElement('div');
        overlay.className = 'custom-confirm-overlay';
        overlay.innerHTML = `
            <div class="custom-confirm-dialog">
                <div class="confirm-icon reset-icon">
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="23 4 23 10 17 10"></polyline>
                        <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"></path>
                    </svg>
                </div>
                <h3 class="confirm-title">Generate Reset Link</h3>
                <p class="confirm-message">Generate password reset link for <strong>${email}</strong>?</p>
                <div class="confirm-actions">
                    <button class="confirm-btn cancel-btn" onclick="this.closest('.custom-confirm-overlay').remove()">Cancel</button>
                    <button class="confirm-btn primary-btn" id="confirmResetBtn">Generate</button>
                </div>
            </div>
        `;
        document.body.appendChild(overlay);
        setTimeout(() => overlay.classList.add('active'), 10);

        document.getElementById('confirmResetBtn').onclick = () => {
            overlay.remove();
            onConfirm();
        };
    }

    function showSuccessMessage(message) {
        const toast = document.createElement('div');
        toast.className = 'toast-notification success';
        toast.innerHTML = `
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            <span>${message}</span>
        `;
        document.body.appendChild(toast);
        setTimeout(() => toast.classList.add('show'), 10);
        setTimeout(() => {
            toast.classList.remove('show');
            setTimeout(() => toast.remove(), 300);
        }, 3000);
    }

    function showErrorMessage(message) {
        const toast = document.createElement('div');
        toast.className = 'toast-notification error';
        toast.innerHTML = `
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"></circle>
                <line x1="12" y1="8" x2="12" y2="12"></line>
                <line x1="12" y1="16" x2="12.01" y2="16"></line>
            </svg>
            <span>${message}</span>
        `;
        document.body.appendChild(toast);
        setTimeout(() => toast.classList.add('show'), 10);
        setTimeout(() => {
            toast.classList.remove('show');
            setTimeout(() => toast.remove(), 300);
        }, 3000);
    }

    // Prevent caching issues when navigating back or switching views
    // Force page reload if accessed via browser back/forward navigation
    window.addEventListener('pageshow', (event) => {
        if (event.persisted) {
            window.location.reload();
        }
    });

</script>

