@using Microsoft.AspNetCore.Identity

@{
    var title = ViewBag.Title ?? "Tracker";
    var isHomePage = title == "Home";
    var isAdmin = User.IsInRole("Admin");
    var isEmployee = User.IsInRole("Employee");
    var isUser = User.IsInRole("User");
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <title>@title - TrackIT</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="manifest" href="~/manifest.json" />
    <meta name="theme-color" content="#0d6efd" />
    <link rel="apple-touch-icon" href="~/icons/tracker-icon.png" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    @await RenderSectionAsync("Styles", required: false)

    <style>
        body {
            font-family: 'Segoe UI', sans-serif;
            margin: 0;
            overflow-x: hidden;
        }

      
        .sidebar {
            position: fixed;
            top: 0;
            left: 0;
            width: 240px;
            height: 100vh;
            background: #212529;
            color: white;
            overflow-y: auto;
            z-index: 1000;
            padding-top: 1rem;
        }

            .sidebar h4 {
                padding-left: 1rem;
                color: #fff;
            }

            .sidebar a {
                color: #adb5bd;
                text-decoration: none;
                display: block;
                padding: .75rem 1rem;
                transition: background 0.2s ease;
            }

                .sidebar a.active,
                .sidebar a:hover {
                    background: #343a40;
                    color: #fff;
                }

      
        .content-area {
            margin-left: 240px;
            padding: 2rem;
            min-height: 100vh;
            overflow-y: auto;
            background: #f8f9fa;
        }

     
        @@media (max-width: 768px) {
            .sidebar

        {
            display: none !important;
        }

        .content-area {
            margin-left: 0 !important;
            padding: 1rem;
        }

        .navbar-toggler {
            border-color: rgba(255, 255, 255, 0.5);
        }

        }

      
        .offcanvas.sidebar {
            position: static !important;
            width: 100% !important;
            height: auto !important;
            margin-left: 0 !important;
            padding-top: 0 !important;
        }

        .offcanvas-body a {
            color: #adb5bd;
            text-decoration: none;
            display: block;
            padding: .75rem 1rem;
            transition: background 0.2s ease;
        }

            .offcanvas-body a:hover {
                background: #343a40;
                color: #fff;
            }
    </style>
</head>

<body>
    @if (isHomePage)
    {
   
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
            <div class="container-fluid">
                <a class="navbar-brand" href="/">Tracker</a>
                <div class="d-flex">
                    <a href="@Url.Action("Index", "Login")" class="btn btn-outline-light">Login</a>
                </div>
            </div>
        </nav>

        <main class="container py-4">
            @RenderBody()
        </main>
    }
    else
    {
        <div class="container-fluid">
            <div class="row">
               
                <nav class="col-md-2 d-none d-md-block sidebar">
                    <div class="p-3">
                        <h4>Tracker</h4>

                        @if (isAdmin)
                        {
                            <a href="@Url.Action("Dashboard", "Admin")" class="@(title=="Dashboard"?"active":"")">Dashboard</a>
                            <a href="@Url.Action("UsersList", "Admin")" class="@(title=="Users"?"active":"")">Users</a>
                            @* <a href="@Url.Action("AddUser", "Admin")" class="@(title=="Add User"?"active":"")">Add User</a> *@
                            @* <a href="@Url.Action("AddDevice", "Admin")" class="@(title=="Add Device"?"active":"")">Add Device</a> *@
                            <a href="@Url.Action("DeviceList", "Admin")" class="@(title=="Device List"?"active":"")">Trackers</a>
                            <a href="@Url.Action("LiveMap", "Admin")" class="@(title == "Live Map" ? "active" : "")">Live Map</a>
                            <hr />
                            <a href="@Url.Action("Settings", "Admin")" class="@(title=="Settings"?"active":"")">Settings</a>
                        }
                        else if (isUser)
                        {
                            <a href="@Url.Action("Dashboard", "User")" class="@(title=="Dashboard"?"active":"")">Dashboard</a>
                            <a href="@Url.Action("LiveMap", "User")" class="@(title=="Live Map"?"active":"")">Live Map</a>
                            <a href="@Url.Action("TrackerList", "User")" class="@(title=="Tracker List"?"active":"")">Tracker List</a>
                            <hr />
                            <a href="@Url.Action("Settings", "User")" class="@(title == "Settings" ? "active" : "")">Settings</a>
                        }

                        <a href="@Url.Action("Logout", "Login")">Logout</a>
                    </div>
                </nav>

            
                <nav class="navbar navbar-dark bg-dark d-md-none">
                    <div class="container-fluid">
                        <button class="navbar-toggler" type="button" data-bs-toggle="offcanvas" data-bs-target="#mobileSidebar" aria-controls="mobileSidebar">
                            <span class="navbar-toggler-icon"></span>
                        </button>
                        <span class="navbar-brand">Tracker</span>
                    </div>
                </nav>

               
                <div class="offcanvas offcanvas-start text-bg-dark" tabindex="-1" id="mobileSidebar" aria-labelledby="mobileSidebarLabel">
                    <div class="offcanvas-header border-bottom">
                        <h5 class="offcanvas-title" id="mobileSidebarLabel">Tracker</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="Close"></button>
                    </div>
                    <div class="offcanvas-body">
                        @if (isAdmin)
                        {
                            <a href="@Url.Action("Dashboard", "Admin")">Dashboard</a>
                            <a href="@Url.Action("UsersList", "Admin")">Users</a>
                            <a href="@Url.Action("AddUser", "Admin")">Add User</a>
                            <a href="@Url.Action("AddDevice", "Admin")">Add Device</a>
                            <a href="@Url.Action("DeviceList", "Admin")">Trackers</a>
                            <a href="@Url.Action("LiveMap", "Admin")">Live Map</a>

                            <hr class="text-secondary" />
                            <a href="@Url.Action("Settings", "Admin")">Settings</a>
                        }
                        else if (isUser)
                        {
                            <a href="@Url.Action("Dashboard", "User")">Dashboard</a>
                            <a href="@Url.Action("LiveMap", "User")">Live Map</a>
                            <a href="@Url.Action("TrackerList", "User")">Tracker List</a>

                            <hr class="text-secondary" />
                            <a href="@Url.Action("Settings", "User")">Settings</a>
                        }

                        <hr class="text-secondary" />
                        <a href="@Url.Action("Logout", "Login")">Logout</a>
                    </div>
                </div>

              
                <main class="col-md-10 ms-sm-auto col-12 content-area">
                    @RenderBody()
                </main>
            </div>
        </div>
    }

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
